# Alchemy RPC API key (free tier) — get one at https://www.alchemy.com/
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Private key of the deployer wallet (DO NOT commit the real .env file!)
DEPLOYER_PRIVATE_KEY=your_wallet_private_key_here

# Etherscan API key for contract verification — https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here
